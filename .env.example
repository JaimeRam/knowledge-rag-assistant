# Anthropic (LLM)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-haiku-4-5

# Voyage AI (Embeddings)
VOYAGE_API_KEY=your_voyage_api_key_here
VOYAGE_EMBEDDING_MODEL=voyage-3

# Ingestion rate limiting (free Voyage tier = 3 RPM, 10K TPM)
# Set INGEST_LIMIT=0 to ingest all Digimon (add payment method first for higher rate limits)
INGEST_LIMIT=100
VOYAGE_EMBED_BATCH_SIZE=20
VOYAGE_RPM=3

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=digimon_knowledge

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=digimon_db
POSTGRES_USER=digimon
POSTGRES_PASSWORD=digimon_pass

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Langfuse
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_NEXTAUTH_SECRET=change_this_secret_in_production
LANGFUSE_SALT=change_this_salt_in_production

# DAPI (Digimon API)
DAPI_BASE_URL=https://digi-api.com/api/v1

# Application
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
